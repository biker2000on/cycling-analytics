# Cycling Analytics — Environment Variables
# Copy to .env.local for local development, or set in your deployment environment.

# ──────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────
# Two deployment modes:
#
# 1. LOCAL DEVELOPMENT (docker-compose.dev.yml)
#    - DB runs in container on port 5433 (5432 is taken by fitnotes-db)
#    - Use: DATABASE_URL=postgresql+asyncpg://cycling_user:cycling_pass@localhost:5433/cycling_analytics
#
# 2. PRODUCTION (docker-compose.yml)
#    - DB runs on external NAS server
#    - Set DB_HOST, DB_PORT, DB_USER, DB_PASS, DB_NAME below
#    - DATABASE_URL is auto-constructed in docker-compose from these vars
#
# 3. STANDALONE (docker-compose.full.yml)
#    - DB included in compose stack
#    - Set DB_USER, DB_PASS, DB_NAME below (defaults provided)

# Database connection components (for production/external DB)
DB_HOST=nas.local
DB_PORT=5432
DB_USER=cycling_user
DB_PASS=cycling_pass
DB_NAME=cycling_analytics

# Direct URLs (for local development when DB is in docker-compose.dev.yml)
# Async driver (FastAPI / SQLAlchemy async)
DATABASE_URL=postgresql+asyncpg://cycling_user:cycling_pass@localhost:5433/cycling_analytics
# Sync driver (Celery workers / Alembic)
SYNC_DATABASE_URL=postgresql+psycopg2://cycling_user:cycling_pass@localhost:5433/cycling_analytics

# ─── Redis ───────────────────────────────────────────────────────────────────
# Celery broker=db0, results=db1, cache=db2
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_DB=2

# ─── File Storage ────────────────────────────────────────────────────────────
FIT_STORAGE_PATH=./data/fit_files

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=Cycling Analytics
APP_PORT=8000
SECRET_KEY=change-me-in-production
DEBUG=true
FRONTEND_URL=http://localhost:5173
